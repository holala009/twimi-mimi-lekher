                        </div>
                        <input type="tel" id="cardNumber" name="cardNumber" placeholder="Kartennummer" maxlength="23"
                            autocomplete="cc-number">
                        <div class="">
                            <svg style="color: #0e8c08; margin-right: 10px;" class="_1VGf3jqj _3AQe3_EI" alt=""
                                xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 1024 1024" width="1em"
                                height="1em" fill="#0e8c08" aria-hidden="true">
                                <path
                                    d="M453.8 53.5c33.4-13.3 70.5-13.5 104.1-0.7l340.5 130.2c41.2 15.7 67.6 56 65.7 100l-8.2 190.2c-6.9 160.5-88.2 308.6-219.8 400.6l-116.5 81.6c-67 46.8-156.1 46.8-223.1 0l-115.1-80.5c-131.5-92-211.7-240.8-216.2-401.2l-5.4-191.4c-1.2-43 24.6-82.2 64.6-98.1z m258.7 327.4c-15.8-16.1-41.8-16.4-57.9-0.5l-178.8 175.5-89.9-81.2c-16.8-15.2-42.7-13.8-57.9 3-15.2 16.8-13.8 42.7 2.9 57.8l118.6 107.1c16.1 14.5 40.7 14 56.2-1.2l206.3-202.6c16.1-15.8 16.4-41.8 0.5-57.9z">
                                </path>
                            </svg>
                        </div>
                    </div>
                    <span class="error-text">! Bitte gib die Kartennummer ein.</span>
                </div>

                <div class="form-row">
                    <div class="form-group expiry-group" id="group-expDate">
                        <label>* Ablaufdatum</label>
                        <div class="input-wrapper">
                            <input type="tel" id="expDate" name="expDate" placeholder="MM/JJ" maxlength="5"
                                autocomplete="cc-exp">
                        </div>
                        <span class="error-text">Bitte ein gültiges Ablaufdatum eingeben.</span>
                    </div>

                    <div class="form-group cvv-group" id="group-cvv">
