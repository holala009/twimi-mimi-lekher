                    <div class="sec-item" style="display: flex;  gap: 10px;">
                        <div>
                            <svg xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 1024 1024" width="1em"
                                height="1em" fill="#0e8c08" class="checkIcon-jy5RO" aria-hidden="true">
                                <path d="M930.4 227.8l-108.2-84.8-409.5 522.4-243.1-188.7-84.3 108.6 351.2 272.7z">
