            </div>

            <div class="modal-header">
                <h2>Eine neue Karte hinzufügen</h2>
                <div class="security-badge">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path
                            d="M12 2C9.243 2 7 4.243 7 7v3H6c-1.103 0-2 .897-2 2v8c0 1.103.897 2 2 2h12c1.103 0 2-.897 2-2v-8c0-1.103-.897-2-2-2h-1V7c0-2.757-2.243-5-5-5zm-3 5c0-1.654 1.346-3 3-3s3 1.346 3 3v3H9V7zm8 13H5v-8h14v8z">
